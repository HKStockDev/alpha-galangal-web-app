# ---------------------------------------------------------------------------
# Reference for Vercel → Project → Settings → Environment Variables (Production)
# Copy the values you need into Vercel; this file is not loaded automatically.
# ---------------------------------------------------------------------------

# Your deployed API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=

# --- Pre-launch (only .vercel.app) — one URL for marketing + app: ---
NEXT_PUBLIC_APP_BASE_URL=https://alpha-galangal.vercel.app
APP_CANONICAL_URL=https://alpha-galangal.vercel.app
MARKETING_CANONICAL_URL=https://alpha-galangal.vercel.app
# NEXT_PUBLIC_MARKETING_BASE_URL=https://alpha-galangal.vercel.app

# --- Or split: marketing = default deploy URL, app = app.*.vercel.app ---
# (Add both domains on the same Vercel project. Example hostnames:)
# MARKETING_CANONICAL_URL=https://alpha-galangal.vercel.app
# APP_CANONICAL_URL=https://app.alpha-galangal.vercel.app
# NEXT_PUBLIC_APP_BASE_URL=https://app.alpha-galangal.vercel.app
# Middleware: app.*.vercel.app = app; primary VERCEL_URL host = marketing.

# --- After you connect withconviction.ai (example): ---
# NEXT_PUBLIC_APP_BASE_URL=https://app.withconviction.ai
# APP_CANONICAL_URL=https://app.withconviction.ai
# MARKETING_CANONICAL_URL=https://www.withconviction.ai
# NEXT_PUBLIC_MARKETING_BASE_URL=https://www.withconviction.ai
# (Middleware still recognizes withconviction.ai / www from code.)

# Analytics — only loaded after the visitor accepts the matching cookie category.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx
