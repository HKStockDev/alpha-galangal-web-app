# ---------------------------------------------------------------------------
# Copy to `.env.local` and adjust. Never commit `.env.local`.
# ---------------------------------------------------------------------------

# Backend API (required for login and app data)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public site / middleware (local dev: marketing = localhost, app = app.localhost)
# Add to /etc/hosts:  127.0.0.1  app.localhost
NEXT_PUBLIC_APP_BASE_URL=http://app.localhost:3000
APP_CANONICAL_URL=http://app.localhost:3000
MARKETING_CANONICAL_URL=http://localhost:3000

# Exposed to the browser so “open public” links from the app (app.localhost) use the marketing host.
# Match MARKETING_CANONICAL_URL (no trailing slash).
NEXT_PUBLIC_MARKETING_BASE_URL=http://localhost:3000

# Analytics — only loaded after the visitor accepts the matching cookie category.
# Leave unset to disable the script entirely (banner still works, the toggles just no-op).
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# Optional: extra hostnames (comma-separated). Use if you use a non-standard
# marketing or app host (e.g. a preview URL). app.*.vercel.app is app by default
# in code; MARKETING_HOSTNAMES= is rarely needed.
# MARKETING_HOSTNAMES=
# APP_HOSTNAMES=

# ---------------------------------------------------------------------------
# Vercel (Production)
# ---------------------------------------------------------------------------
# One URL (marketing + app on same host) — all three the same, e.g.:
#   NEXT_PUBLIC_APP_BASE_URL=
#   APP_CANONICAL_URL=
#   MARKETING_CANONICAL_URL=
#   = https://alpha-galangal.vercel.app
#
# Or split hosts: add e.g. app.alpha-galangal.vercel.app in Vercel → same project
# → Domains. Code treats app.*.vercel.app as the app host. Then:
#   MARKETING_CANONICAL_URL=https://alpha-galangal.vercel.app
#   APP_CANONICAL_URL=https://app.alpha-galangal.vercel.app
#   NEXT_PUBLIC_APP_BASE_URL=https://app.alpha-galangal.vercel.app
# NEXT_PUBLIC_API_URL=https://your-api.example.com
